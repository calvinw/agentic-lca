{
  "name": "AI Agentic Tools + openLCA",

  "image": "ghcr.io/calvinw/ai-course-devcontainer:latest",

  // Forward the openLCA gdt-server port so it's accessible in the browser
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "openLCA gdt-server",
      "onAutoForward": "silent"
    }
  },

  // Start the gdt-server as a Docker sidecar after the container launches.
  // Docker-in-Docker must be enabled — add "ghcr.io/devcontainers/features/docker-in-docker:2"
  // to the features block if it isn't already.
  "postStartCommand": "bash .devcontainer/start_olca.sh",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  // Install the Python client library on container start
  "postCreateCommand": "pip install olca-ipc olca-schema --break-system-packages"
}
